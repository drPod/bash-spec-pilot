# Copy this file to .env and fill in real values. .env is gitignored.

# Required: API key for OpenAI. Create one at https://platform.openai.com/api-keys
# (Sign up at https://platform.openai.com/signup if you don't have an account.)
# Add at least a few dollars of credit at https://platform.openai.com/settings/organization/billing
OPENAI_API_KEY=sk-...

# Pinned model snapshot. We pin the dated snapshot rather than the floating "gpt-5.5"
# alias so reruns months from now still hit the same weights. Verified against
# https://developers.openai.com/api/docs/models/gpt-5.5 on 2026-05-06.
# Pricing (per 1M tokens): $5 input / $30 output / $0.50 cached input.
# Context: 1,050,000 in / 128,000 out. GA, not preview.
OPENAI_MODEL=gpt-5.5-2026-04-23

# Sampling controls.
# - `temperature` and `top_p` are rejected by GPT-5.5 reasoning models ("Unsupported
#   parameter: 'temperature' is not supported with this model.").
# - `seed` is a Chat Completions parameter; it is not on the Responses API at all.
#   The SDK signature for responses.create() does not accept it.
# - `system_fingerprint` is a Chat Completions response field; the Responses API
#   does not return it. We log `response_id` from the Responses payload instead.
# Reproducibility now relies on: dated model snapshot + sha256(prompt template) +
# sha256(manpage). See docs/openai/responses_create.md for the verified param list.

# Optional: reasoning depth. minimal | low | medium | high. Unset = model default.
# Higher = more internal reasoning tokens = slower + more expensive. Note:
# OPENAI_MAX_OUTPUT_TOKENS is a hard cap that *includes* reasoning tokens; raise
# both together when going to high effort.
OPENAI_REASONING_EFFORT=medium

# Optional: raise if you hit truncation on long man pages (e.g. find(1)).
OPENAI_MAX_OUTPUT_TOKENS=16000

# Optional: where per-run JSONL logs land. Driver creates one subdir per run.
RUNS_DIR=runs
